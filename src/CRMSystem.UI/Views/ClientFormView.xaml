<Window x:Class="CRMSystem.UI.Views.ClientFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CRMSystem.UI.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="520"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/Resources/app-icon.ico"
        d:DataContext="{d:DesignInstance Type=vm:ClientFormViewModel}">

    <Window.Resources>
        <!-- Style that shows a red border + tooltip when validation fails -->
        <Style x:Key="ValidatedTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red" />
                    <Setter Property="ToolTip"
                            Value="{Binding (Validation.Errors)/ErrorContent, RelativeSource={RelativeSource Self}}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="First Name *" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="FirstNameBox"
                     Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            <TextBlock Style="{StaticResource ErrorText}"
                       Text="{Binding ElementName=FirstNameBox, Path=(Validation.Errors)[0].ErrorContent}"
                       Visibility="{Binding ElementName=FirstNameBox, Path=(Validation.HasError), Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="Last Name *" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="LastNameBox"
                     Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            <TextBlock Style="{StaticResource ErrorText}"
                       Text="{Binding ElementName=LastNameBox, Path=(Validation.Errors)[0].ErrorContent}"
                       Visibility="{Binding ElementName=LastNameBox, Path=(Validation.HasError), Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="Company" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="CompanyBox"
                     Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding Company, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            <TextBlock Style="{StaticResource ErrorText}"
                       Text="{Binding ElementName=CompanyBox, Path=(Validation.Errors)[0].ErrorContent}"
                       Visibility="{Binding ElementName=CompanyBox, Path=(Validation.HasError), Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="Email *" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="EmailBox"
                     Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            <TextBlock Style="{StaticResource ErrorText}"
                       Text="{Binding ElementName=EmailBox, Path=(Validation.Errors)[0].ErrorContent}"
                       Visibility="{Binding ElementName=EmailBox, Path=(Validation.HasError), Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}" />
            <TextBox x:Name="PhoneBox"
                     Style="{StaticResource ValidatedTextBox}"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
            <TextBlock Style="{StaticResource ErrorText}"
                       Text="{Binding ElementName=PhoneBox, Path=(Validation.Errors)[0].ErrorContent}"
                       Visibility="{Binding ElementName=PhoneBox, Path=(Validation.HasError), Converter={StaticResource BoolToVisibilityConverter}}" />

            <TextBlock Text="Status" Style="{StaticResource FieldLabel}" />
            <ComboBox ItemsSource="{Binding AvailableStatuses}"
                      SelectedItem="{Binding SelectedStatus}"
                      Padding="6,4" />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource ErrorText}"
                   Margin="0,10,0,10" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Padding="20,6"
                    Margin="0,0,10,0" />
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Padding="20,6"
                    Background="#2B313D"
                    Foreground="White" />
        </StackPanel>
    </Grid>
</Window>