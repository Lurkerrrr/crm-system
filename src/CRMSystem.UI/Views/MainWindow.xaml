<Window x:Class="CRMSystem.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CRMSystem.UI.ViewModels"
        xmlns:views="clr-namespace:CRMSystem.UI.Views"
        mc:Ignorable="d"
        Title="CRM System"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app-icon.ico"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <!-- DataTemplates map each ViewModel type to its View -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientListViewModel}">
            <views:ClientListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientDetailsViewModel}">
            <views:ClientDetailsView />
        </DataTemplate>

        <!-- Sidebar button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="10,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A4252" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#2B313D">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="20,25,20,20">
                    <StackPanel>
                        <TextBlock Text="CRM System"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <StackPanel>
                    <Button Content="Dashboard"
                            Style="{StaticResource NavButton}"
                            Command="{Binding GoToDashboardCommand}" />
                    <Button Content="Clients"
                            Style="{StaticResource NavButton}"
                            Command="{Binding GoToClientsCommand}" />
                    <Button Content="Reports"
                            Style="{StaticResource NavButton}"
                            Command="{Binding GoToReportsCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>